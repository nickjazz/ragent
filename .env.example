# =============================================================================
# ragent — Environment Variables
# Usage: cp .env.example .env  →  fill REQUIRED vars  →  start API + worker
# =============================================================================

# -----------------------------------------------------------------------------
# 4.6.1  Bootstrap & HTTP server
# -----------------------------------------------------------------------------
RAGENT_ENV=dev                        # REQUIRED — set before boot (dev|staging|prod)
RAGENT_AUTH_MODE=user_header          # none|user_header|jwt_header|jwt_prefer_header (none/user_header/jwt_prefer_header require RAGENT_ENV=dev)
RAGENT_USER_ID_HEADER=X-User-Id       # canonical user-id header name (inbound in user_header/jwt_prefer_header; downstream-injected in jwt_header)
RAGENT_JWT_HEADER=X-Auth-Token        # jwt_header/jwt_prefer_header only — inbound header carrying raw JWT (no 'Bearer ' prefix)
RAGENT_JWT_CLAIM_USER_ID=preferred_username  # jwt_header/jwt_prefer_header only — JWT payload claim path used as downstream user_id
OIDC_DOMAIN=                          # REQUIRED for jwt_header/jwt_prefer_header — OIDC issuer domain (JWKS at {scheme}://<domain>/.well-known/jwks.json)
OIDC_AUDIENCE=                        # REQUIRED for jwt_header/jwt_prefer_header — expected `aud` claim
RAGENT_JWT_VERIFY_AUD=true            # jwt_header/jwt_prefer_header only — set false to skip audience check (requires RAGENT_ENV=dev)
RAGENT_JWT_VERIFY_EXP=true            # jwt_header/jwt_prefer_header only — set false to skip expiry check (requires RAGENT_ENV=dev)
OIDC_USE_HTTPS=true                   # P2 only — scheme toggle for OIDC discovery + JWKS URL; set false ONLY for in-cluster / local fixture
OIDC_VERIFY_SSL=true                  # P2 only — verify the IdP's TLS cert; set false ONLY for dev/staging against self-signed Keycloak. For prod with private CA, leave true and mount the CA via SSL_CERT_FILE instead.
RAGENT_PERMISSION_INGEST_ENABLED=false # P2 only — enable PermissionClient gate on GET/DELETE/LIST ingest
RAGENT_PERMISSION_CHAT_ENABLED=false  # P2 only — enable PermissionClient post-filter on chat retrieval
RAGENT_HOST=127.0.0.1                 # API bind address
RAGENT_PORT=8000                      # API bind port
LOG_LEVEL=INFO                        # DEBUG|INFO|WARNING|ERROR
CORS_ALLOW_ORIGINS=                   # comma-separated allowed origins; unset = deny all cross-origin

# -----------------------------------------------------------------------------
# 4.6.2  Datastore connections (boot-blocking)
# -----------------------------------------------------------------------------
MARIADB_DSN=                          # REQUIRED — set before boot (mysql+aiomysql://db_user:db_pass@host:3306/ragent?charset=utf8mb4)  # pragma: allowlist secret
MARIADB_POOL_RECYCLE_SECONDS=280      # pool_recycle; must be < server wait_timeout (default 280 s)
ES_HOSTS=                             # REQUIRED — set before boot (comma-separated https?://host:port)
ES_USERNAME=                          # basic-auth username; omit for unauthenticated dev
ES_PASSWORD=                          # basic-auth password
ES_API_KEY=                           # alternative to username/password (mutually exclusive)
ES_VERIFY_CERTS=true                  # set false for self-signed dev clusters
ES_CHUNKS_INDEX=chunks_v1             # chunks index name; bootstrap PUTs chunks_v1.json schema under this name; App threads via Container (T-EI.1 / T-EI.6 / B60)
# Multi-site MinIO registry (v2 §4.6.2). Inline JSON list; one entry per site.
# `__default__` is REQUIRED — used by inline ingest to stage content. Other
# sites are referenced by name from `POST /ingest` ingest_type=file requests.
# `read_only=true` sites refuse post-READY delete (we don't own the object).
MINIO_SITES=                          # REQUIRED — JSON list, e.g.
                                      # [{"name":"__default__","endpoint":"localhost:9000","access_key":"minioadmin","secret_key":"example_secret_key_not_real","bucket":"ragent","secure":false},  # pragma: allowlist secret
                                      #  {"name":"tenant-eu-1","endpoint":"eu.example:9000","access_key":"...","secret_key":"...","bucket":"tenant-eu","secure":true,"read_only":true}]
# DEPRECATED single-site vars (kept for backward-compat reads during v2 rollout;
# removed in a follow-up cleanup commit. Prefer MINIO_SITES.):
MINIO_ENDPOINT=                       # legacy single-site endpoint (v1)
MINIO_ACCESS_KEY=                     # legacy
MINIO_SECRET_KEY=                     # legacy
MINIO_SECURE=false                    # legacy
MINIO_BUCKET=ragent                   # legacy

# -----------------------------------------------------------------------------
# 4.6.3  Redis (B27)
# -----------------------------------------------------------------------------
REDIS_MODE=standalone                 # standalone|sentinel
REDIS_BROKER_URL=redis://localhost:6379/0       # TaskIQ broker URL (mode=standalone)
REDIS_RATELIMIT_URL=redis://localhost:6379/1    # rate-limiter URL (mode=standalone)
REDIS_STREAM_URL=redis://localhost:6379/2       # resumable v3 stream buffer URL (mode=standalone)
REDIS_SENTINEL_HOSTS=                 # REQUIRED — set before boot (if mode=sentinel): comma-separated host:port
REDIS_BROKER_SENTINEL_MASTER=ragent-broker      # master name for broker (mode=sentinel)
REDIS_RATELIMIT_SENTINEL_MASTER=ragent-ratelimit  # master name for rate-limiter (mode=sentinel)
REDIS_STREAM_SENTINEL_MASTER=stream-master      # master name for v3 stream buffer (mode=sentinel)
REDIS_STREAM_TTL_SECONDS=300          # how long a finished v3 run stays resumable
REDIS_STREAM_MAXLEN=10000             # approximate per-run frame cap (XADD MAXLEN ~) for v3 buffer
REDIS_UNREAD_TTL_SECONDS=2592000      # TTL of the per-session new-reply flag (30d) — sessionList dot
CHATAGENT_STREAM_IDLE_TIMEOUT_SECONDS=30  # consumer gives up if the v3 buffer sees no new frame for this long
NATS_SERVERS=                         # comma-separated NATS URLs (shared platform NATS); unset → snapshot-only
NATS_AUTH_SERVICE_URL=                # NATS auth service base URL; ragent POSTs <url>/api/v1/auth (app flow) for a NATS JWT
NATS_AUTH_CLIENT_SECRET=              # app client_secret for the app-flow auth exchange
NATS_AUTH_NAMESPACE=                  # app namespace sent in the app-flow exchange
NATS_AUTH_VERIFY_CERTS=true           # set false for a self-signed/broken-chain auth-service CA (dev only)
NATS_SESSION_SUBJECT_TEMPLATE=session.{user}.status  # per-user status subject; {user} → user id
NATS_CONNECT_TIMEOUT_SECONDS=10       # bounds the lifespan-startup nats.connect() call (nats-py retries ~2min otherwise)
NATS_JWT_REFRESH_SECONDS=30           # fallback proactive-reconnect cadence when auth omits expiresIn (must be < JWT TTL ~1min)

# -----------------------------------------------------------------------------
# 4.6.4  Third-party API endpoints & credentials
# -----------------------------------------------------------------------------
AI_API_AUTH_URL=                      # REQUIRED — set before boot (TokenManager J1->J2 endpoint)
AI_LLM_API_J1_TOKEN=                  # REQUIRED (local mode) — J1 token for LLM service (never logged, never echoed)
AI_EMBEDDING_API_J1_TOKEN=            # REQUIRED (local mode) — J1 token for Embedding service (never logged, never echoed)
AI_RERANK_API_J1_TOKEN=               # REQUIRED (local mode) — J1 token for Rerank service (never logged, never echoed)
AI_USE_K8S_SERVICE_ACCOUNT_TOKEN=false  # Set true on K8s; reads SA token file; overrides J1_TOKEN vars above
EMBEDDING_API_URL=                    # REQUIRED — set before boot (bge-m3 endpoint)
LLM_API_URL=                          # REQUIRED — set before boot (gptoss-120b endpoint)
RERANK_API_URL=                       # REQUIRED — set before boot (rerank endpoint, wired in P2)
EMBEDDING_AUTH_HEADER_NAME=Authorization  # HTTP auth header sent by EmbeddingClient; raw J2 token value (no Bearer prefix)
LLM_AUTH_HEADER_NAME=Authorization    # HTTP auth header sent by LLMClient; raw J2 token value (no Bearer prefix)
RERANK_AUTH_HEADER_NAME=Authorization  # HTTP auth header sent by RerankClient; raw J2 token value (no Bearer prefix)
# B50 — embedding-model lifecycle (admin /embedding/v1/*). Stable / candidate
# model identity lives in system_settings table; App refreshes the cache
# every EMBEDDING_REGISTRY_TTL_SECONDS. COMMIT_MIN_HOURS gates how soon
# after cutover the operator may commit, to discourage impulsive merges.
EMBEDDING_REGISTRY_TTL_SECONDS=10     # TTL on the ActiveModelRegistry settings cache (seconds)
COMMIT_MIN_HOURS=24                   # minimum observation window in CUTOVER before /commit allowed
HR_API_URL=                           # OpenFGA-related role lookup (P2+, future)
CHATAGENT_API_URL=                    # optional; when set, enables POST /chatagent/v1 proxy
CHATAGENT_SESSIONLIST_API_URL=        # optional; when set, enables GET /chatagent/v1/sessionList proxy
CHATAGENT_SESSION_API_URL=            # optional; when set, enables GET /chatagent/v1/session proxy
CHATAGENT_AP_NAME=ragent              # apName injected into all outbound chatagent requests
CHATAGENT_AUTH=                       # optional; raw Authorization header value (e.g. "Basic <base64>"); NEVER log
TWP_DEFAULT_MODEL=                    # optional; fallback model for POST /twp/v1/run when the request body omits "model"
UNPROTECT_ENABLED=false              # set true to call the unprotect API before ingest pipeline
UNPROTECT_API_URL=                   # REQUIRED when UNPROTECT_ENABLED=true — full URL of the unprotect endpoint
UNPROTECT_APIKEY=                    # REQUIRED when UNPROTECT_ENABLED=true — raw JWT (no Bearer prefix) sent as apikey header; NEVER log
UNPROTECT_DELEGATED_USER_SUFFIX=     # REQUIRED when UNPROTECT_ENABLED=true — appended to X-User-Id to form delegatedUser field
RAGENT_KEK_BASE64=                   # optional; base64 Key-Encryption-Key (32 bytes) — set together with RAGENT_ENCRYPTED_DEK_BASE64 to enable chat attachments; NEVER log
RAGENT_ENCRYPTED_DEK_BASE64=         # REQUIRED when RAGENT_KEK_BASE64 set — base64 Data-Encryption-Key, AES-Key-Wrapped under the KEK; NEVER log

# -----------------------------------------------------------------------------
# 4.6.5  Worker, Reconciler & retry policy
# -----------------------------------------------------------------------------
WORKER_HEARTBEAT_INTERVAL_SECONDS=10  # how often worker refreshes updated_at during pipeline; set RECONCILER_PENDING_STALE_SECONDS >= 3x this
WORKER_MAX_ATTEMPTS=5                 # pipeline gives up and marks FAILED once attempt > this
PIPELINE_TIMEOUT_SECONDS=1800         # overall pipeline-body wall-clock ceiling (30 min)
RECONCILER_PENDING_STALE_SECONDS=300  # re-dispatch threshold for PENDING rows with aged heartbeat
RECONCILER_UPLOADED_STALE_SECONDS=300 # re-kiq threshold for UPLOADED orphans
RECONCILER_DELETING_STALE_SECONDS=300 # resume threshold for stuck DELETING cascades

# -----------------------------------------------------------------------------
# 4.6.6  Pipeline & chat tunables
# -----------------------------------------------------------------------------
# v2 ingest size limits (§3.1):
INGEST_INLINE_MAX_BYTES=10485760      # 10 MB cap on inline JSON `content` (UTF-8 byte length); 413 on overrun
INGEST_FILE_MAX_BYTES=52428800        # 50 MB cap on file-type ingest (HEAD-probe at API time); 413 on overrun
INGEST_LIST_MAX_LIMIT=100             # GET /ingest?limit= upper bound
ATTACHMENT_MAX_SIZE_BYTES=52428800    # 50 MB cap on chat-attachment upload bytes; 413 ATTACHMENT_TOO_LARGE on overrun
ATTACHMENT_ARTIFACT_MAX_CHARS=10000   # complete-AST char_count budget; DocumentArtifactResolver falls back to simplified above this, and truncates whichever variant is selected past this length
ATTACHMENT_TOTAL_MAX_CHARS=50000      # per-turn aggregate cap on injected attachment content across all attachments; truncates/omits content once spent
ATTACHMENT_MAX_FILES=10               # max attachment_ids per /chatagent/v3 turn; RUN_ERROR ATTACHMENT_TOO_MANY_FILES on overrun
# DOCX/PPTX archive preflight (security/archive_guard.py); 413 INGEST_ARCHIVE_UNSAFE on overrun
INGEST_MAX_ARCHIVE_MEMBERS=5000       # max zip entries per upload (defeats millions-of-tiny-files bomb)
INGEST_MAX_ARCHIVE_RATIO=100          # max sum(file_size) / len(raw); defeats 42.zip-style bombs
INGEST_MAX_ARCHIVE_EXPANDED_BYTES=524288000  # 500 MB absolute cap on Σ uncompressed sizes (and per-member)
INGEST_MAX_PDF_PAGES=2000             # PDF preflight: cap on fitz.Document.page_count; 413 INGEST_PDF_TOO_MANY_PAGES on overrun
INGEST_PDF_MARGIN_PTS=0               # PDF header/footer exclusion zone in PDF points (1 pt ≈ 0.35 mm); 0 = disabled
INGEST_PDF_USE_OCR=false              # Enable selective OCR for scanned PDFs; false = text-layer only (fast default)
INGEST_PDF_OCR_CHAR_THRESHOLD=50      # Pages with fewer extractable chars than this are treated as scanned (image-only)
INGEST_PDF_OCR_MAX_SCANNED_PAGES=10   # Max scanned pages per document; exceeded → FAILED with INGEST_PDF_OCR_PAGES_EXCEEDED
INGEST_PDF_OCR_DPI=150                # DPI for RapidOCR pixmap rendering (150 ≈ same detection quality as 300, ~4x faster)
INGEST_PDF_OCR_THREADS=2              # intra_op_num_threads for the RapidOCR ONNX engine singleton (worker startup only)
# v2 unified chunker (§3.2): single profile, mime-agnostic. Replaces the v1
# language/CSV-specific knobs (CHUNK_TARGET_CHARS_EN/CJK/CSV — removed).
CHUNK_TARGET_CHARS=1000               # target char count per chunk
CHUNK_MAX_CHARS=1500                  # hard cap; atoms above this are hard-split
CHUNK_OVERLAP_CHARS=100               # overlap between adjacent chunks
EMBEDDER_BATCH_SIZE=32                # chunks per embedder HTTP call
CHAT_JOIN_MODE=rrf                    # rrf|concatenate|vector_only|bm25_only
CHAT_RERANK_ENABLED=true              # set false to skip the bge-reranker stage
RETRIEVAL_TOP_K=20                    # top_k applied to retrievers, joiner, and reranker
RETRIEVAL_MIN_SCORE=                  # optional post-pipeline score floor; unset = no filtering
EXCERPT_MAX_CHARS=512                 # SourceHydrator truncation length
RAGENT_DEFAULT_LLM_PROVIDER=openai   # echoed when request omits provider
RAGENT_DEFAULT_LLM_MODEL=gptoss-120b  # echoed when request omits model
RAGENT_DEFAULT_LLM_TEMPERATURE=0.7
RAGENT_DEFAULT_LLM_MAX_TOKENS=4096
# Leave blank to use the built-in multi-intent RAG template (GREETING/QUESTION/SUMMARY/GENERATION).
RAGENT_DEFAULT_RAG_SYSTEM_PROMPT=
# Leave blank to use the built-in rules-only grounding variant (prepended when caller supplies system).
RAGENT_RAG_GROUNDING_RULES=
CHAT_RATE_LIMIT_PER_MINUTE=30        # per-user request cap on /chat + /chat/stream
CHAT_RATE_LIMIT_WINDOW_SECONDS=60    # fixed-window length for rate limit
MCP_REQUEST_MAX_BYTES=262144         # 256 KiB defence-in-depth cap on POST /mcp/v1; 413 on overrun

# Feedback retrieval signal (B50/B51/B52/B53, T-FB.*) — ship dark by default.
CHAT_FEEDBACK_ENABLED=false           # master switch; true also enables POST /feedback/v1 + 3rd RRF input
CHAT_FEEDBACK_RRF_WEIGHT=0.5          # DocumentJoiner weights=[1.0, 1.0, this]; keep < 1.0
CHAT_FEEDBACK_MIN_VOTES=3             # min (likes+dislikes) per (source_app, source_id) to score
CHAT_FEEDBACK_HALF_LIFE_DAYS=14       # Wilson score decay half-life
FEEDBACK_HMAC_SECRET=                 # REQUIRED when CHAT_FEEDBACK_ENABLED=true

# -----------------------------------------------------------------------------
# 4.6.7  Per-call timeouts
# -----------------------------------------------------------------------------
EMBEDDER_INGEST_TIMEOUT_SECONDS=30   # per-batch (32 strings) ingest call
EMBEDDER_QUERY_TIMEOUT_SECONDS=10    # single-string chat-query call
ES_BULK_TIMEOUT_SECONDS=60           # VectorExtractor bulk index/delete
ES_QUERY_TIMEOUT_SECONDS=10          # chat retrievers (vector + BM25)
MINIO_GET_TIMEOUT_SECONDS=30         # worker download from staging
MINIO_GET_RETRIES=3                  # max attempts for transient MinIO GET errors (clamped to ≥1)
MINIO_GET_RETRY_DELAY_SECONDS=2.0    # sleep between MinIO GET retry attempts
MINIO_PUT_TIMEOUT_SECONDS=60         # router upload to staging
LLM_TIMEOUT_SECONDS=120              # LLMClient.{chat|stream}
PLUGIN_FAN_OUT_TIMEOUT_SECONDS=60    # per-plugin extract/delete ceiling
READYZ_PROBE_TIMEOUT_SECONDS=2       # per-dependency /readyz probe budget
UNPROTECT_TIMEOUT_SECONDS=30         # per-call budget for the unprotect API POST (UNPROTECT_ENABLED=true only)
CHATAGENT_TIMEOUT_SECONDS=30         # per-call timeout for all chatagent proxy HTTP calls

# -----------------------------------------------------------------------------
# 4.6.8  Observability (OpenTelemetry)
# -----------------------------------------------------------------------------
OTEL_EXPORTER_OTLP_ENDPOINT=         # OTLP collector URL; absence disables export
OTEL_SERVICE_NAME=ragent-api         # ragent-api|ragent-worker|ragent-reconciler
OTEL_TRACES_SAMPLER=parentbased_traceidratio
OTEL_TRACES_SAMPLER_ARG=0.1          # sampling ratio (raise to 1.0 in dev)
HAYSTACK_TELEMETRY_ENABLED=false     # disable Haystack anonymous usage analytics (PostHog)
HAYSTACK_CONTENT_TRACING_ENABLED=false # set true to include prompts/answers in OTEL spans (sensitive)
RAGENT_METRICS_SOURCE_APP_ALLOWLIST=  # comma-separated source_app values exposed as labels; others collapse to fallback
RAGENT_METRICS_SOURCE_APP_FALLBACK=other # bucket name for source_app values outside the allow-list
HTTP_ERROR_LOG_MAX_BYTES=8192        # max bytes of request/response body logged in http.upstream_error records (above = truncated)
