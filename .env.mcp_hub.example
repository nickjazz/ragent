# =============================================================================
# ragent MCP Hub — Environment Variables
# Usage: cp .env.mcp_hub.example .env.mcp_hub  →  edit values  →  run hub
# =============================================================================

# Tool registry (file or directory of yaml files)
MCP_HUB_TOOLS_YAML=src/ragent/mcp_hub/tools.example.d

# MCP server identity / bind
MCP_HUB_NAME=ragent-mcp-hub
MCP_HUB_HOST=0.0.0.0
MCP_HUB_PORT=9000
MCP_HUB_PATH=/mcp

# Transport behavior
# true  => no server-side MCP session state required
# false => normal sessionful streamable HTTP behavior
MCP_HUB_STATELESS_HTTP=false

# true  => return JSON responses (no SSE framing)
# false => default streamable/SSE response behavior
MCP_HUB_JSON_RESPONSE=false
