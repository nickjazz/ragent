FROM docker.elastic.co/elasticsearch/elasticsearch:9.2.3

# Manual/staging CJK BM25 smoke image. Fail the build if the ICU analyzer cannot
# be installed; otherwise the smoke test can pass against the wrong analyzer.
RUN bin/elasticsearch-plugin install --batch analysis-icu

ENV discovery.type=single-node
ENV xpack.security.enabled=false
ENV cluster.routing.allocation.disk.threshold_enabled=false
ENV ES_JAVA_OPTS="-Xms512m -Xmx512m"
